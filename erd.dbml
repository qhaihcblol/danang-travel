Project DanangTravel {
  database_type: "PostgreSQL"
}

// Enums

Enum service_type {
  hotel
  tour
}

Enum booking_status {
  pending
  confirmed
  cancelled
  completed
}

Enum payment_status {
  unpaid
  paid
  refunded
  failed
}

Enum payment_method {
  cod
  bank_transfer
  card
  ewallet
}

Enum media_type {
  image
  video
}

Enum user_role {
  customer
  admin
}

// Main entities

Table users {
  id uuid [pk]

  email varchar [unique, not null]
  password_hash text [not null]

  full_name varchar [not null]
  phone varchar

  role user_role [not null, default: 'customer']

  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp

  indexes {
    (role)
  }
}

Table locations {
  id uuid [pk]

  name varchar [not null]
  address_line text [not null]
  ward varchar [not null]
  district varchar [not null]
  province varchar [not null, default: 'Da Nang']

  latitude decimal(10, 7)
  longitude decimal(10, 7)

  created_at timestamp [not null]
  updated_at timestamp [not null]

  indexes {
    (province, district, ward)
    (district, ward)
  }
}

Table vendors {
  id uuid [pk]

  name varchar [not null]
  contact_email varchar
  phone varchar

  created_at timestamp [not null]
  updated_at timestamp [not null]
}

Table services {
  id uuid [pk]

  name varchar [not null]
  slug varchar [unique, not null]

  description text
  type service_type [not null]

  location_id uuid [ref: > locations.id, not null]
  vendor_id uuid [ref: > vendors.id, not null]

  rating_avg decimal(2, 1) [default: 0]
  total_reviews int [default: 0]

  is_active boolean [default: true]

  created_at timestamp [not null]
  updated_at timestamp [not null]
  deleted_at timestamp

  constraints {
    `rating_avg >= 0 and rating_avg <= 5` [name: 'chk_services_rating_avg']
    `total_reviews >= 0` [name: 'chk_services_total_reviews_non_negative']
  }

  indexes {
    (type)
    (location_id)
    (vendor_id)
    (type, location_id)
    (rating_avg)
  }
}

// Service subtypes

Table hotel {
  service_id uuid [pk, ref: > services.id]

  room_count int
  checkin_time time
  checkout_time time

  star_rating int

  created_at timestamp [not null]
  updated_at timestamp [not null]

  constraints {
    `star_rating is null or (star_rating >= 1 and star_rating <= 5)` [name: 'chk_hotel_star_rating']
  }
}

Table tour {
  service_id uuid [pk, ref: > services.id]
  
  meeting_point text
  includes text
  excludes text
  created_at timestamp [not null]
  updated_at timestamp [not null]
}

// Hotel and tour offerings

Table hotel_rooms {
  id uuid [pk]

  service_id uuid [ref: > hotel.service_id, not null]

  name varchar [not null]
  description text

  max_guests int [not null]
  bed_type varchar

  base_price decimal(12, 2) [not null]

  created_at timestamp [not null]
  updated_at timestamp [not null]

  constraints {
    `max_guests > 0` [name: 'chk_hotel_rooms_max_guests_positive']
    `base_price >= 0` [name: 'chk_hotel_rooms_base_price_non_negative']
  }

  indexes {
    (service_id)
  }
}

Table tour_packages {
  id uuid [pk]

  service_id uuid [ref: > tour.service_id, not null]

  name varchar [not null]
  description text

  base_price decimal(12, 2) [not null]

  max_participants int
  duration_minutes int

  created_at timestamp [not null]
  updated_at timestamp [not null]

  constraints {
    `base_price >= 0` [name: 'chk_tour_packages_base_price_non_negative']
    `max_participants is null or max_participants > 0` [name: 'chk_tour_packages_max_participants_positive']
    `duration_minutes is null or duration_minutes > 0` [name: 'chk_tour_packages_duration_positive']
  }
}

// Dynamic prices

Table room_prices {
  id uuid [pk]

  room_id uuid [ref: > hotel_rooms.id, not null]

  date date [not null]
  price decimal(12, 2) [not null]

  constraints {
    `price >= 0` [name: 'chk_room_prices_non_negative']
  }

  indexes {
    (room_id, date) [unique]
  }
}

Table tour_prices {
  id uuid [pk]

  package_id uuid [ref: > tour_packages.id, not null]

  date date [not null]
  price decimal(12, 2) [not null]

  constraints {
    `price >= 0` [name: 'chk_tour_prices_non_negative']
  }

  indexes {
    (package_id, date) [unique]
  }
}

// Media

Table media {
  id uuid [pk]

  service_id uuid [ref: > services.id, not null]

  url text [not null]
  type media_type [not null]

  is_cover boolean [default: false]
  sort_order int [default: 0]

  created_at timestamp [not null]
  updated_at timestamp [not null]

  Note: 'Add partial unique index in SQL migration: UNIQUE(service_id) WHERE is_cover = true'

  indexes {
    (service_id)
    (service_id, is_cover)
  }
}

Table room_media {
  id uuid [pk]

  room_id uuid [ref: > hotel_rooms.id, not null]

  url text [not null]
  type media_type [not null]

  is_cover boolean [default: false]
  sort_order int [default: 0]

  created_at timestamp [not null]
  updated_at timestamp [not null]

  Note: 'Add partial unique index in SQL migration: UNIQUE(room_id) WHERE is_cover = true'

  indexes {
    (room_id)
    (room_id, is_cover)
  }
}

// Hotel metadata

Table amenities {
  id uuid [pk]
  name varchar [unique, not null]
}

Table hotel_amenities {
  service_id uuid [ref: > hotel.service_id, not null]
  amenity_id uuid [ref: > amenities.id, not null]

  indexes {
    (service_id, amenity_id) [unique]
  }
}

Table hotel_policies {
  service_id uuid [pk, ref: > hotel.service_id]

  checkin_policy text
  cancellation_policy text
  child_policy text
  pet_policy text

  created_at timestamp [not null]
  updated_at timestamp [not null]
}

// User-generated content

Table reviews {
  id uuid [pk]

  service_id uuid [ref: > services.id, not null]
  user_id uuid [ref: > users.id, not null]
  rating int [not null]
  comment text

  created_at timestamp [not null]
  updated_at timestamp [not null]

  constraints {
    `rating >= 1 and rating <= 5` [name: 'chk_reviews_rating']
  }

  indexes {
    (service_id)
    (user_id)
    (service_id, user_id) [unique]
  }
}

// Bookings

Table hotel_bookings {
  id uuid [pk]

  room_id uuid [ref: > hotel_rooms.id, not null]
  user_id uuid [ref: > users.id, not null]

  checkin_date date [not null]
  checkout_date date [not null]
  guests int [not null]

  total_price decimal(12, 2) [not null]
  status booking_status [not null, default: 'pending']

  created_at timestamp [not null]
  updated_at timestamp [not null]

  constraints {
    `checkin_date < checkout_date` [name: 'chk_hotel_bookings_valid_date_range']
    `guests > 0` [name: 'chk_hotel_bookings_guests_positive']
    `total_price >= 0` [name: 'chk_hotel_bookings_total_price_non_negative']
  }

  Note: 'Use PostgreSQL EXCLUDE constraint in SQL migration to prevent overlapping bookings per room.'

  indexes {
    (room_id)
    (user_id)
    (status)
    (checkin_date)
    (checkout_date)
    (created_at)
  }
}

Table tour_bookings {
  id uuid [pk]

  package_id uuid [ref: > tour_packages.id, not null]
  user_id uuid [ref: > users.id, not null]

  travel_date date [not null]
  guests int [not null]

  total_price decimal(12, 2) [not null]
  status booking_status [not null, default: 'pending']

  created_at timestamp [not null]
  updated_at timestamp [not null]

  constraints {
    `guests > 0` [name: 'chk_tour_bookings_guests_positive']
    `total_price >= 0` [name: 'chk_tour_bookings_total_price_non_negative']
  }

  indexes {
    (package_id)
    (user_id)
    (status)
    (travel_date)
    (created_at)
  }
}

Table payments {
  id uuid [pk]

  hotel_booking_id uuid [ref: > hotel_bookings.id]
  tour_booking_id uuid [ref: > tour_bookings.id]

  amount decimal(12, 2) [not null]
  currency varchar [not null, default: 'VND']
  method payment_method [not null]
  status payment_status [not null, default: 'unpaid']

  payment_ref varchar [unique]
  provider_transaction_id varchar

  paid_at timestamp
  created_at timestamp [not null]
  updated_at timestamp [not null]

  constraints {
    `amount >= 0` [name: 'chk_payments_amount_non_negative']
    `((hotel_booking_id is not null)::int + (tour_booking_id is not null)::int) = 1` [name: 'chk_payments_exactly_one_booking']
  }

  indexes {
    (hotel_booking_id)
    (tour_booking_id)
    (status)
    (created_at)
  }
}